{
  "name": "cxl-ac",
  "version": "1.0.0",
  "main": "app/main.js",
  "scripts": {
    "start": "node server/server.js",
    "electron": "electron .",
    "build": "electron-builder build --win",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "description": "CXL AC Anti-Cheat Scanner Tool",
  "author": "CXLx",
  "license": "ISC",
  "build": {
    "appId": "com.cxl.ac",
    "productName": "CXL AC",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "portable",
      "requestedExecutionLevel": "requireAdministrator"
    },
    "files": [
      "app/**/*",
      "package.json"
    ]
  },
  "dependencies": {
    "axios": "^1.13.6",
    "body-parser": "^2.2.2",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "socket.io": "^4.8.3"
  },
  "devDependencies": {
    "electron": "^41.0.3",
    "electron-builder": "^26.8.1",
    "electron-packager": "^17.1.2"
  }
}
